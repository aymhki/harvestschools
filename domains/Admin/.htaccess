<IfModule mod_rewrite.c>
  RewriteEngine On

    # Ensure we don't loop if the request is already for the script
    RewriteCond %{REQUEST_URI} !^/scripts/Public/General/servePublicAssetFile\.php

    # 1. Rule for /assets/
    # Check that the file DOES NOT physically exist in the public directory (allows Vite chunks to load)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^assets/(.+)$ /scripts/Public/General/servePublicAssetFile.php?path=$1 [QSA,L]

    # 2. Rule for /images, /videos, /documents, /fonts
    # Check that the file DOES NOT physically exist in the public directory
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^(images|videos|documents|fonts)/(.+)$ /scripts/Public/General/servePublicAssetFile.php?path=$1/$2 [QSA,L]

  DirectoryIndex index.html
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>


# php -- BEGIN cPanel-generated handler, do not edit
# Set the “ea-php84” package as the default “PHP” programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php84 .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit

# BEGIN cPanel-generated php ini directives, do not edit
# Manual editing of this file may result in unexpected behavior.
# To make changes to this file, use the cPanel MultiPHP INI Editor (Home >> Software >> MultiPHP INI Editor)
# For more information, read our documentation (https://go.cpanel.net/EA4ModifyINI)
<IfModule php8_module>
   php_flag display_errors Off
   php_value upload_max_filesize 128M
   php_value post_max_size 128M
   php_value max_execution_time 120
   php_value max_input_time 190
   php_value max_input_vars 1000
   php_value memory_limit 512M
   php_value session.gc_maxlifetime 1440
   php_value session.save_path "/var/cpanel/php/sessions/ea-php84"
   php_flag zlib.output_compression Off
</IfModule>
<IfModule lsapi_module>
   php_flag display_errors Off
   php_value upload_max_filesize 128M
   php_value post_max_size 128M
   php_value max_execution_time 120
   php_value max_input_time 190
   php_value max_input_vars 1000
   php_value memory_limit 512M
   php_value session.gc_maxlifetime 1440
   php_value session.save_path "/var/cpanel/php/sessions/ea-php84"
   php_flag zlib.output_compression Off
</IfModule>
# END cPanel-generated php ini directives, do not edit
