{
  "name": "MobileApp",
  "type": "module",
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1"
  },
  "scripts": {
    "dev": "vite --port 5175",
    "android": "npx cap run android",
    "ios": "npx cap run ios --target-name \"iPhone 16e\"",
    "build": "rm -rf ../../dist/mobile-app && vite build --outDir ../../dist/mobile-app && npx cap sync"
  }
}
