    "students-union-page": {
      "students-union-title": "Students Union",
      "how-can-i-join-the-students-union-question": "How can I join the Students Union?",
      "how-can-i-join-the-students-union-answer": "In order to join the students union, students enrolled in the highest education stages must pass two examination stages created by the current students union, one of which is written (held in classrooms randomly) and the other one is oral held in the meetings room in the national premises. If a student passed the two exams successfully a judging committee consist of head teachers from all the subjects look through the history of all students to filter the best of which can represent the new students union.",
      "what-are-the-students-union-duties-question": "What are the Students Union duties?",
      "what-are-the-students-union-duties-answer": [
        "To represent Harvest Schools students outlook and behavior.",
        "To provide and protect a healthy environment for the rest of the students during the school time and summer time.",
        "To create new ideas that help teachers and administrators in the school management systems.",
        "To organize school trips and moderate champions during the year."
      ],
      "what-are-the-students-union-benefits-question": "What are the Students Union benefits?",
      "what-are-the-students-union-benefits-answer": [
        "Special access to all school facilities and resources such as libraries, computer labs, Stationery and Canteen.",
        "A decision making voice in meetings related Books, Stationary, and E - Learning devices.",
        "Discounts and offers for all school trips and products sold or services used.",
        "Leading classrooms in playgrounds, swimming pool and gymnasium for competitions and champions among students."
      ],
      "who-are-the-students-union-members-right-now-question": "Who are the students union members right now?",
      "who-are-the-students-union-members-right-now-answer": [
        "From Middle 1: Mariam Mohamed, Darin Ahmed",
