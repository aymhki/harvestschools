{
  "name": "harvestschools",
  "private": true,
  "workspaces": [
    "domains/Admin",
    "domains/Main",
    "domains/MobileApp"
  ],
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "postinstall": "patch-package",
    "dev:main": "npm run dev --workspace=domains/Main",
    "dev:admin": "npm run dev --workspace=domains/Admin",
    "dev:android-mobile-app": "npm run android --workspace=domains/MobileApp",
    "dev:ios-mobile-app": "npm run ios --workspace=domains/MobileApp",
    "dev:mobile-app": "npm run dev --workspace=domains/MobileApp",
    "build:main": "npm run build --workspace=domains/Main",
    "build:admin": "npm run build --workspace=domains/Admin",
    "build:mobile-app": "npm run build --workspace=domains/MobileApp",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "clean": "rm -rf dist",
    "preview": "vite preview"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/network": "^8.0.1",
    "@capgo/capacitor-native-biometric": "^8.6.0",
    "@capgo/capacitor-updater": "^8.50.2",
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@mui/icons-material": "^5.15.16",
    "@mui/material": "^5.15.16",
    "@mui/x-date-pickers": "^8.2.0",
    "axios": "^1.7.3",
    "capacitor-secure-storage-plugin": "^0.13.0",
    "i18next": "^25.6.2",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-fs-backend": "^2.6.6",
    "i18next-http-backend": "^3.0.6",
    "i18next-resources-to-backend": "^1.2.1",
    "jspdf": "^4.0.0",
    "lodash.debounce": "^4.0.8",
    "prop-types": "^15.8.1",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.2.0",
    "react-google-recaptcha": "^3.1.0",
    "react-helmet-async": "^2.0.5",
    "react-i18next": "^16.2.4",
    "react-intersection-observer": "^9.10.3",
    "react-modal": "^3.16.1",
    "react-router-dom": "^6.23.0",
    "react-slick": "^0.30.2",
    "react-spring": "^9.7.3",
    "uuid": "^11.1.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "patch-package": "^8.0.1",
    "postinstall-postinstall": "^2.1.0",
    "typescript": "^6.0.3",
    "vite": "^7.2.2"
  },
  "snap": {
    "source": "dist",
    "script": "serve",
    "port": 45678
  },
  "allowScripts": {
    "postinstall-postinstall@2.1.0": true,
    "esbuild@0.28.1": true,
    "core-js": false,
    "fsevents@2.3.3": true
  }
}
